CREATE DATABASE PeluqueriaElCojo;
GO
USE PeluqueriaElCojo;

-- Para el Módulo de Clientes
CREATE TABLE Clientes (
    Id INT PRIMARY KEY IDENTITY,
    Nombre NVARCHAR(100) NOT NULL,
    Telefono NVARCHAR(15),
    Visitas INT DEFAULT 0,
    Tipo NVARCHAR(20) -- Nuevo, Regular, VIP
);

-- Para el Módulo de Empleados
CREATE TABLE Empleados (
    Id INT PRIMARY KEY IDENTITY,
    Nombre NVARCHAR(100) NOT NULL,
    Apodo NVARCHAR(50),
    Cedula NVARCHAR(15) UNIQUE,
    SueldoBase DECIMAL(18,2),
    ComisionPorcentaje DECIMAL(5,2)
);

-- Para el Módulo de Inventario
CREATE TABLE Productos (
    Codigo NVARCHAR(50) PRIMARY KEY, -- Para IEquatable
    Nombre NVARCHAR(100) NOT NULL,
    Precio DECIMAL(18,2),
    Costo DECIMAL(18,2),
    Stock INT
);

-- Sistema de Facturación
CREATE TABLE Facturas (
    Id INT PRIMARY KEY IDENTITY,
    Fecha DATETIME DEFAULT GETDATE(),
    ClienteId INT FOREIGN KEY REFERENCES Clientes(Id),
    EmpleadoId INT FOREIGN KEY REFERENCES Empleados(Id),
    Subtotal DECIMAL(18,2),
    Descuento DECIMAL(18,2),
    ITBIS DECIMAL(18,2),
    Total DECIMAL(18,2)
);

CREATE TABLE DetalleFactura (
    Id INT PRIMARY KEY IDENTITY,
    FacturaId INT FOREIGN KEY REFERENCES Facturas(Id),
    ServicioNombre NVARCHAR(100),
    Precio DECIMAL(18,2)
);
